# Ports
WAYFINDER_CDP_PORT=9000
WAYFINDER_SERVER_PORT=9100
WAYFINDER_EXTENSION_PORT=9300
# BROWSER_USE_NEW_TOOLS=true

# Directories (optional - defaults to cwd)
# WAYFINDER_RESOURCES_DIR=./resources
# WAYFINDER_EXECUTION_DIR=./out

# Wayfinder config
WAYFINDER_VERSION=
WAYFINDER_INSTALL_ID=
WAYFINDER_CLIENT_ID=

WAYFINDER_TRUSTED_ORIGINS=

# Telemetry
POSTHOG_API_KEY=
SENTRY_DSN=

NODE_ENV=development
LOG_LEVEL=info

# AI SDK DevTools
# 1. Set WAYFINDER_AI_SDK_DEVTOOLS=true in apps/server/.env.development.
# 2. Run `cd apps/server && bun run devtools` to open the viewer.
#    From the monorepo root, `bun run devtools` opens the same viewer.
# 3. In another apps/server terminal, run `bun run start` and use the agent.
# 4. Confirm the `AI SDK DevTools middleware enabled` log line; captures need a v3 model.
# WAYFINDER_AI_SDK_DEVTOOLS=true

# Testing
WAYFINDER_TEST_HEADLESS=false
